{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeuroVue",
  "version": "0.1.0",
  "identifier": "org.neurovue.app",
  "build": {
    "beforeDevCommand": "npm run ensure-niimath && npm run dev",
    "devUrl": "http://127.0.0.1:5175",
    "beforeBuildCommand": "npm run ensure-niimath && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeuroVue",
        "width": 1480,
        "height": 940,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:*",
        "img-src": "'self' http://127.0.0.1:* data: blob:",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*",
        "img-src": "'self' http://127.0.0.1:* data: blob:",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/niimath"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
